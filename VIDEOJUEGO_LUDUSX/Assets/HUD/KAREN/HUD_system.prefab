  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2d0e85f2219b598439c317f8ef1ac337, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ConsejeroManager
  panelConsejero: {fileID: 556945415392064578}
  textoUI: {fileID: 3751528325105478994}
  spriteConsejero: {fileID: 8971198067238718396}
  textoInicio: "Los profesores han sido absorbidos por los 25 a\xF1os del programa
    y tu misi\xF3n es liberarlos para restaurar el orden en la carrera de multimedia.
    Recuerda estar atento a halos de luz que te pueden ayudar a vencer a los enemigos
    que aparezcan por el mapa."
  Textochoque: "Trata de no chocar con ellos, aunque si te hacen mucho da\xF1o, siempre
    puedes ir al Coase"
  textoColeccionable: "Bien hecho, sigue buscandolos\t"
  textoBoss: "Este enemigo no se ve como los dem\xE1s, ten m\xE1s cuidado al atacar."
  textoarma: "\xA1Has recogido el arma! Ahora puedes enfrentarte a los enemigos con
    m\xE1s poder."
  textonivel: "Un lugar curioso...\xBFeso de all\xED es un arma?"
  velocidadTexto: 0.03
  duracionMensaje: 5
